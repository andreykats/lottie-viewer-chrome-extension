{
  "manifest_version": 3,
  "name": "Lottie JSON Viewer",
  "version": "1.0.0",
  "description": "Automatically previews Lottie animation files (.json, .lottie) opened in Chrome with a full-featured player.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "file:///*/*.json",
        "file:///*/*.lottie",
        "http://*/*/*.json",
        "https://*/*/*.json",
        "http://*/*/*.lottie",
        "https://*/*/*.lottie"
      ],
      "js": ["lib/lottie.min.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
